# Database Configuration
DATABASE_URL="mysql://root:your_password@127.0.0.1:3306/thaitienshop"
PORT=3000

# AWS S3 Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your_bucket_name

# Redis Configuration (Optional for local)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_ACCESS_SECRET="your_access_token_secret_key"
JWT_REFRESH_SECRET="your_refresh_token_secret_key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email Configuration (Resend API)
RESEND_API_KEY="your_resend_api_key"

# Application URLs
FRONTEND_URL="http://localhost:5173"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5173/auth/google/callback"

# SePay Configuration (Payment)
SEPAY_API_KEY=your_sepay_api_key
SEPAY_API_SECRET=your_sepay_api_secret
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_CODE=your_bank_code
